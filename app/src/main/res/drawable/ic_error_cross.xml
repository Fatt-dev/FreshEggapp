        android:strokeColor="#000000"
        android:strokeWidth="0.5"
        android:strokeAlpha="0.1"
        android:pathData="M20,60 L100,60 M60,20 L60,100 M40,30 L40,90 M80,30 L80,90 M30,40 L90,40 M30,80 L90,80"/>

    <!-- Outline Hitam untuk Silang (X) -->
