        android:strokeColor="#000000"
        android:strokeWidth="14"
        android:strokeLineCap="round"
        android:pathData="M42,42 L78,78 M78,42 L42,78"/>

    <!-- Silang Merah -->
    <path
        android:strokeColor="#FF3333"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:pathData="M42,42 L78,78 M78,42 L42,78"/>
        
</vector>
