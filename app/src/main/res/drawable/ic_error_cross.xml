    android:height="120dp"
    android:viewportWidth="120"
    android:viewportHeight="120">
    
    <!-- Lingkaran Kuning Latar Belakang dengan Garis Tepi Hitam -->
    <path
        android:fillColor="#FCD02C"
        android:strokeColor="#000000"
        android:strokeWidth="4"
        android:pathData="M60,60 m-50,0 a50,50 0 1,1 100,0 a50,50 0 1,1 -100,0"/>

    <!-- Pola Kotak-kotak Halus di dalam lingkaran (Retro Grid) -->
